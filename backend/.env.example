# ============================================================
# backend/.env.example
# Copiez ce fichier en .env et remplissez les vraies valeurs
# COMMANDE : copy .env.example .env  (Windows)
# ============================================================

SECRET_KEY=votre-cle-secrete-a-generer
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données
DB_NAME=buscam_db
DB_USER=buscam_user
DB_PASSWORD=votre-mot-de-passe
DB_HOST=localhost
DB_PORT=5432

# URL du frontend (pour CORS)
FRONTEND_URL=http://localhost:5173

# En production (Render), ces valeurs changent :
# DEBUG=False
# ALLOWED_HOSTS=votre-app.onrender.com
# DB_HOST=votre-host-postgresql-render
# FRONTEND_URL=https://votre-app.vercel.app